# Application
APP_NAME=CrossSync
APP_VERSION=0.1.0
DEBUG=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./crosssync.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/crosssync

# Supabase (optional — used only in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Redis (optional — used for rate limiting and sessions)
REDIS_URL=redis://localhost:6379/0

# Anthropic (AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321
